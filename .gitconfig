[alias]
    a = add
    alias = config --get-regexp alias
    amend = commit --amend
    c = commit
    cm = commit -m
    co = checkout
    cob = checkout -b
    cp = cherry-pick
    last = log -1 HEAD
    p = push
    pl = pull
    recent = "!git for-each-ref --sort=-committerdate refs/heads/ --format='%(refname:short) | %(objectname:short) | %(contents:subject) (%(committerdate:relative))' | fzf --ansi --preview 'git log --oneline --graph --color=always {1} -- | head -20' --preview-window=right:50% | awk -F' \\\\| ' '{print $1}' | xargs -r git checkout"
    rh = reset --hard
    s = status
[core]
    editor = nvim
    pager = bat
[diff]
    colorMoved = zebra
[fetch]
    prune = true
[http]
    postBuffer = 524288000
[hub]
    protocol = https
[pull]
    rebase = true
[push]
    autoSetupRemote = true
[user]
    email = git@bjornkrols.com
    name = botre
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[credential]
	helper = store
