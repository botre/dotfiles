#!/usr/bin/env bash

set -e

echo "Configuring desktop settings for Hyprland..."

# Window-manager behaviour (compose key, scrolling, animations, keybinds)
# lives in ~/.config/hypr/hyprland.lua. The gsettings below only affect GTK
# applications, which still read them even without GNOME Shell running.

# Use 24-hour clock format
gsettings set org.gnome.desktop.interface clock-format '24h'

# Always show scroll bars
gsettings set org.gnome.desktop.interface overlay-scrolling false

# Prefer a light colour scheme (matches the Catppuccin Latte terminal theme)
gsettings set org.gnome.desktop.interface color-scheme 'default'

echo "Done"
